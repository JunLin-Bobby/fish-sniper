# Allowed frontend origin for CORS — set to your Cloudflare Pages URL in production
FRONTEND_ORIGIN=http://localhost:5173

# Skip JWT validation — ONLY for local development, MUST be false/absent in production
SKIP_AUTH=false

# Fixed user id used when SKIP_AUTH=true (must exist in Supabase `users` if you hit protected routes)
SKIP_AUTH_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# Supabase (server-side only — never expose service role key to the browser)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend (server-side only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FishSniper <no-reply@yourdomain.com>

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
